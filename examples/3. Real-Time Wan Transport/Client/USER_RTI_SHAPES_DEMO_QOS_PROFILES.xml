<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.7.0/rti_dds_qos_profiles.xsd"
     version="7.7.0">

    <qos_library name="HospitalWanDemoLib">

        <!-- Internal hospital participant -->
        <qos_profile name="HospitalInternalBase"
                     base_name="BuiltinQosLib::Generic.StrictReliable">
            <base_name>
                <element>BuiltinQosSnippetLib::Transport.UDP.WAN</element>
                <element>BuiltinQosSnippetLib::Transport.UDP.AvoidIPFragmentation</element>
                <element>BuiltinQosSnippetLib::Optimization.Discovery.Common</element>
            </base_name>

            <domain_participant_qos>
                <transport_builtin>
                    <mask>UDPv4_WAN</mask>
                    <udpv4_wan>
                        <comm_ports>
                            <default>
                                <host>7401</host>
                            </default>
                        </comm_ports>
                    </udpv4_wan>
                </transport_builtin>

                <discovery>
                    <initial_peers>
                        <element>rtps@udpv4_wan://HUB_PUBLIC_IP:HUB_PUBLIC_PORT</element>
                    </initial_peers>
                    <multicast_receive_addresses/>
                </discovery>

            </domain_participant_qos>
        </qos_profile>

        <!-- External remote console participant -->
        <qos_profile name="RemoteMonitorBase"
                     base_name="BuiltinQosLib::Generic.StrictReliable">
            <base_name>
                <element>BuiltinQosSnippetLib::Transport.UDP.WAN</element>
                <element>BuiltinQosSnippetLib::Transport.UDP.AvoidIPFragmentation</element>
                <element>BuiltinQosSnippetLib::Optimization.Discovery.Common</element>
            </base_name>

            <domain_participant_qos>
                <transport_builtin>
                    <mask>UDPv4_WAN</mask>
                    <udpv4_wan>
                        <comm_ports>
                            <default>
                                <host>7401</host>
                            </default>
                        </comm_ports>
                    </udpv4_wan>
                </transport_builtin>

                <discovery>
                    <initial_peers>
                        <element>rtps@udpv4_wan://HUB_PUBLIC_IP:HUB_PUBLIC_PORT</element>
                    </initial_peers>
                    <multicast_receive_addresses/>
                </discovery>
            </domain_participant_qos>
        </qos_profile>

    </qos_library>
</dds>