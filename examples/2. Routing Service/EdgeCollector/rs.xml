<?xml version="1.0"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.3.1/rti_routing_service.xsd">

    <routing_service name="EdgeCollector">

        <domain_route name="LanToWanTunnel">

            <!-- Local DDS side: collects traffic from the local subnet/domain -->
            <participant name="LanSide">
                <domain_id>0</domain_id>
                <domain_participant_qos>
                    <transport_builtin>
                        <mask>UDPv4</mask>
                    </transport_builtin>
                </domain_participant_qos>
            </participant>

            <!-- WAN side: sends/receives through a single predetermined UDP port -->
            <participant name="WanSide">
                <domain_id>1</domain_id>
                <domain_participant_qos>
                    <transport_builtin>
                        <mask>UDPv4_WAN</mask>
                        <udpv4_wan>
                            <comm_ports>
                                <default>
                                    <host>7400</host>
                                </default>
                            </comm_ports>
                        </udpv4_wan>
                    </transport_builtin>
                    <discovery>
                        <initial_peers>
                            <element>0@udpv4_wan://REMOTE_HUB_PUBLIC_IP:7400</element>
                        </initial_peers>
                    </discovery>
                </domain_participant_qos>
            </participant>

            <!-- Forward everything from LAN to WAN -->
            <session name="LanToWan">
                <auto_topic_route name="AllForward">
                    <publish_with_original_info>true</publish_with_original_info>
                    <input participant="LanSide">
                        <allow_topic_name_filter>*</allow_topic_name_filter>
                        <allow_registered_type_name_filter>*</allow_registered_type_name_filter>
                    </input>
                    <output participant="WanSide">
                        <allow_topic_name_filter>*</allow_topic_name_filter>
                        <allow_registered_type_name_filter>*</allow_registered_type_name_filter>
                    </output>
                </auto_topic_route>
            </session>

            <!-- Bring remote traffic back into the local DDS domain -->
            <session name="WanToLan">
                <auto_topic_route name="AllBackward">
                    <publish_with_original_info>true</publish_with_original_info>
                    <input participant="WanSide">
                        <allow_topic_name_filter>*</allow_topic_name_filter>
                        <allow_registered_type_name_filter>*</allow_registered_type_name_filter>
                    </input>
                    <output participant="LanSide">
                        <allow_topic_name_filter>*</allow_topic_name_filter>
                        <allow_registered_type_name_filter>*</allow_registered_type_name_filter>
                    </output>
                </auto_topic_route>
            </session>

        </domain_route>
    </routing_service>
</dds>