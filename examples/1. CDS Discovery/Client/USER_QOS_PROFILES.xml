<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.3.1/rti_dds_qos_profiles.xsd"
  version="7.3.1">
  <qos_library name="CDSQoSLib">
    <qos_profile name="RouterCDSTest">
      <domain_participant_qos>
        <!-- Use UDPv4 only (disable SHMEM and UDPv6) -->
        <transport_builtin>
          <mask>UDPv4</mask>
          <udpv4>
            <multicast_enabled>false</multicast_enabled>
          </udpv4>
        </transport_builtin>


        <!-- Initial peers list for discovery -->
        <discovery>
          <initial_peers>
            <element>rtps@udpv4://192.168.1.1:7400</element>
          </initial_peers>
          <multicast_receive_addresses />
        </discovery>
      </domain_participant_qos>
    </qos_profile>
  </qos_library>
</dds>