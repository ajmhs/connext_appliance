<?xml version="1.0" encoding="UTF-8"?>

<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/7.3.1/dds_security_permissions.xsd">
    <permissions>
        <grant name="Participant_A">
            <!-- This subject name needs to exactly match the value in the corresponding identity cert. -->
            <subject_name>C=US, ST=CA, L=Sunnyvale, O=My Company, CN=App_A</subject_name>
            <validity>
                <!-- Format is CCYY-MM-DDThh:mm:ss[Z|(+|-)hh:mm] in GMT -->
                <not_before>2015-06-01T13:00:00</not_before>
                <not_after>2025-06-01T13:00:00</not_after>
            </validity>
            <allow_rule>
                <domains>
                    <id_range>
                        <min>10</min>
                        <max>19</max>
                    </id_range>
                </domains>
                <publish>
                    <topics>
                        <topic>*</topic>
                    </topics>
                    <data_tags>
                        <tag>
                            <name>allowed_color</name>
                            <value>red</value>
                        </tag>
                    </data_tags>
                </publish>
                <subscribe>
                    <topics>
                        <topic>*</topic>
                    </topics>
                </subscribe>
            </allow_rule>
            <default>DENY</default>
        </grant>
    </permissions>
</dds>
